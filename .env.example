# =============================================================================
# Evenly — environment variables
# =============================================================================
# Copy this file to ".env" for local (non-Docker) development:
#     cp .env.example .env
#
# For Docker, docker-compose.yml already injects sensible defaults, so you can
# run `docker compose up` WITHOUT creating a .env at all. Create a .env only to
# override those defaults (e.g. real SMTP credentials for production).
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Local (running the app on the host against the dockerised db on :5432):
DATABASE_URL="postgresql://evenly:evenly@localhost:5432/evenly?schema=public"
# Inside Docker the app uses the compose service name instead of localhost:
#   postgresql://evenly:evenly@db:5432/evenly?schema=public

# These feed the `db` compose service (only used by docker-compose.yml):
POSTGRES_USER="evenly"
POSTGRES_PASSWORD="evenly"
POSTGRES_DB="evenly"

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Host port the app is published on (http://localhost:<APP_PORT>).
APP_PORT="3001"
# Public base URL — used to build absolute links in emails (invites, magic links).
APP_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Secret used to sign session/CSRF tokens. MUST be a long random string in prod.
# Generate one with:  openssl rand -hex 32
AUTH_SECRET="dev-only-insecure-secret-change-me-0123456789abcdef"

# Where uploaded receipts/avatars are stored (a writable directory / volume).
UPLOAD_DIR="./uploads"

# -----------------------------------------------------------------------------
# Email (SMTP via nodemailer)
# -----------------------------------------------------------------------------
# Email requires SMTP, in development too. Fill these in to enable invites,
# magic-link sign-in, verification, password reset and reminders; if SMTP_HOST
# is empty those email features simply do not work. Use any SMTP server in dev
# and a real provider in production.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="false"             # "true" only for real providers using TLS on connect (port 465)
EMAIL_FROM="Evenly <no-reply@evenly.local>"

# For PRODUCTION, plug in a real provider, e.g.:
#   SMTP_HOST="smtp.resend.com"
#   SMTP_PORT="587"
#   SMTP_USER="resend"
#   SMTP_PASS="re_xxxxxxxxxxxx"
#   SMTP_SECURE="false"
#   EMAIL_FROM="Evenly <no-reply@yourdomain.com>"

# -----------------------------------------------------------------------------
# Currency exchange rates (OPTIONAL)
# -----------------------------------------------------------------------------
# The app ships with built-in fallback exchange rates and works fully offline.
# To refresh rates from a live provider in production, set these. The provider
# must return JSON of shape { "rates": { "EUR": 0.92, "GBP": 0.79, ... } } with
# USD as the implicit base (the open exchangerate.host / openexchangerates style).
EXCHANGE_RATE_API_URL=""
EXCHANGE_RATE_API_KEY=""

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
NODE_ENV="development"
