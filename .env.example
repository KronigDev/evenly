# =============================================================================
# Evenly — environment variables
# =============================================================================
# Copy this file to ".env" for local (non-Docker) development:
#     cp .env.example .env
#
# For Docker, docker-compose.yml already injects sensible defaults, so you can
# run `docker compose up` WITHOUT creating a .env at all. Create a .env only to
# override those defaults (e.g. your SMTP credentials).
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Local (running the app on the host against the dockerised db on :5432):
DATABASE_URL="postgresql://evenly:evenly@localhost:5432/evenly?schema=public"
# Inside Docker the app uses the compose service name instead of localhost:
#   postgresql://evenly:evenly@db:5432/evenly?schema=public

# These feed the `db` compose service (only used by docker-compose.yml):
POSTGRES_USER="evenly"
POSTGRES_PASSWORD="evenly"
POSTGRES_DB="evenly"

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Host port the app is published on (http://localhost:<APP_PORT>).
APP_PORT="3000"
# Public base URL — used to build absolute links in emails (invites, magic links).
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Secret used to sign session/CSRF tokens. MUST be a long random string in prod.
# Generate one with:  openssl rand -hex 32
AUTH_SECRET="dev-only-insecure-secret-change-me-0123456789abcdef"

# Self-registration. "false" (default): nobody can sign up on their own — new
# accounts are only created via group invitations. Exception: the very first
# account on a fresh instance can always be created (bootstrap), so a new
# install is never locked out. "true": anyone who can reach the app may register.
REGISTRATION_ENABLED="false"

# Where uploaded receipts/avatars are stored (a writable directory / volume).
UPLOAD_DIR="./uploads"

# -----------------------------------------------------------------------------
# Email (SMTP via nodemailer)
# -----------------------------------------------------------------------------
# Invites, magic-link sign-in, verification, password reset and reminders are
# sent over SMTP. Point these at your SMTP server — e.g. Resend:
#   SMTP_HOST="smtp.resend.com"  SMTP_PORT="587"  SMTP_USER="resend"  SMTP_PASS="re_xxx"
# If SMTP_HOST is empty, these email features are disabled; the rest of the app
# works fully.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="false"             # "true" only for TLS on connect (port 465)
EMAIL_FROM="Evenly <no-reply@evenly.local>"

# -----------------------------------------------------------------------------
# Currency exchange rates
# -----------------------------------------------------------------------------
# Live rates come from ExchangeRate-API's free open endpoint by default
# (https://www.exchangerate-api.com — no API key, rates update daily); the app
# refreshes them automatically once a day. Any other provider works too, as long
# as it returns JSON of shape { "rates": { "EUR": 0.92, ... } } with USD as the
# implicit base. Set EXCHANGE_RATE_API_URL="off" to disable all external calls —
# the app then uses its bundled fallback rates and works fully offline.
EXCHANGE_RATE_API_URL="https://open.er-api.com/v6/latest/USD"
EXCHANGE_RATE_API_KEY=""        # only if your provider needs one (sent as Bearer token)

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
NODE_ENV="development"
