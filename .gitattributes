# Normalize line endings: LF in the repo, so shell scripts work on the Linux
# production host regardless of the OS they were committed from.
* text=auto eol=lf

# Windows-only files keep CRLF.
*.bat text eol=crlf

# Treat binaries as binary (no EOL/normalization).
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ico binary
*.gif binary
*.woff binary
*.woff2 binary
